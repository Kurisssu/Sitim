@page "/studies/{OrthancStudyId}"
@attribute [Authorize]
@inject SitimApiClient Api
@inject NavigationManager Navigation
@inject NotificationService Notification
@inject DialogService Dialog
@inject AuthTokenStore TokenStore

<PageTitle>Studiu — SITIM</PageTitle>

@if (isLoading)
{
    <RadzenProgressBarCircular ProgressBarStyle="ProgressBarStyle.Primary" Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
else if (study is null)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Dark" AllowClose="false">
        Studiul nu a fost găsit.
    </RadzenAlert>
}
else
{
    <RadzenStack Gap="1rem">
        @* ── Header ──────────────────────────────────────── *@
        <RadzenRow AlignItems="AlignItems.Center">
            <RadzenColumn Size="12" SizeMD="8">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenButton Icon="arrow_back" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Size="ButtonSize.Small"
                                  Click="@(() => Navigation.NavigateTo("/studies"))" title="Înapoi la Worklist" />
                    <RadzenText Text="@($"Studiu: {study.PatientName ?? "N/A"}")" TextStyle="TextStyle.DisplayH5" class="rz-mb-0" />
                </RadzenStack>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
                    <RadzenButton Text="Sincronizare" Icon="sync" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small"
                                  Click="@OnSync" />
                    <AuthorizeView Roles="Admin,Doctor,Technician">
                        <RadzenButton Text="Analiză" Icon="science" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small"
                                      Click="@OnStartAnalysis" />
                    </AuthorizeView>
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>

        @* ── Detalii studiu ──────────────────────────────── *@
        <RadzenCard>
            <RadzenText Text="Detalii studiu" TextStyle="TextStyle.H6" class="rz-mb-3" />
            <RadzenRow>
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenStack Gap="0.5rem">
                        <RadzenFormField Text="Pacient" Variant="Variant.Text"><ChildContent><RadzenTextBox ReadOnly="true" Value="@(study.PatientName ?? "—")" Style="width: 100%;" /></ChildContent></RadzenFormField>
                        <RadzenFormField Text="ID Pacient" Variant="Variant.Text"><ChildContent><RadzenTextBox ReadOnly="true" Value="@(study.PatientId ?? "—")" Style="width: 100%;" /></ChildContent></RadzenFormField>
                        <RadzenFormField Text="Data studiu" Variant="Variant.Text"><ChildContent><RadzenTextBox ReadOnly="true" Value="@FormatStudyDate(study.StudyDate)" Style="width: 100%;" /></ChildContent></RadzenFormField>
                    </RadzenStack>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenStack Gap="0.5rem">
                        @if (!IsDoctor)
                        {
                            <RadzenFormField Text="Orthanc ID" Variant="Variant.Text"><ChildContent><RadzenTextBox ReadOnly="true" Value="@study.OrthancStudyId" Style="width: 100%; font-family: monospace;" /></ChildContent></RadzenFormField>
                            <RadzenFormField Text="Study Instance UID" Variant="Variant.Text"><ChildContent><RadzenTextBox ReadOnly="true" Value="@(study.StudyInstanceUid ?? "—")" Style="width: 100%; font-family: monospace; font-size: 0.85rem;" /></ChildContent></RadzenFormField>
                        }
                        <div>
                            <RadzenText Text="Modalități" TextStyle="TextStyle.Body2" class="rz-mb-1" style="color: var(--rz-text-tertiary-color);" />
                            @foreach (var mod in study.ModalitiesInStudy)
                            {
                                <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@mod" class="rz-mr-1" />
                            }
                        </div>
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
            @if (!IsDoctor)
            {
                <RadzenText Text="@($"Serii: {study.SeriesOrthancIds.Count}")" TextStyle="TextStyle.Caption" class="rz-mt-3" style="color: var(--rz-text-tertiary-color);" />
            }
        </RadzenCard>

        @* ── OHIF Viewer ─────────────────────────────────── *@
        <RadzenCard>
            <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" class="rz-mb-3">
                <RadzenColumn>
                    <RadzenText Text="Vizualizare OHIF" TextStyle="TextStyle.H6" class="rz-mb-0" />
                </RadzenColumn>
                <RadzenColumn>
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
                        @if (!string.IsNullOrWhiteSpace(viewerUrl))
                        {
                            <RadzenButton Text="Deschide în tab nou" Icon="open_in_new" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                          Click="@OpenViewerExternal" />
                        }
                        else if (viewerUnavailable)
                        {
                            <RadzenButton Text="Reîncearcă viewer" Icon="refresh" ButtonStyle="ButtonStyle.Warning" Size="ButtonSize.Small"
                                          Click="@LoadViewerUrl" IsBusy="@isLoadingViewer" BusyText="Se încarcă..." />
                        }
                        else
                        {
                            <RadzenButton Text="Încarcă viewer" Icon="play_arrow" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small"
                                          Click="@LoadViewerUrl" IsBusy="@isLoadingViewer" BusyText="Se încarcă..." />
                        }
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>

            @if (!string.IsNullOrWhiteSpace(viewerUrl))
            {
                <div style="width: 100%; height: 600px; border: 1px solid var(--rz-border-color); border-radius: var(--rz-border-radius);">
                    <iframe src="@viewerUrl" style="width: 100%; height: 100%; border: none; border-radius: var(--rz-border-radius);" allowfullscreen></iframe>
                </div>
            }
            else if (viewerUnavailable)
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Light" AllowClose="false" class="rz-my-2">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                        <RadzenIcon Icon="cloud_off" />
                        <span>Serverul PACS (Orthanc) nu este disponibil momentan. Vizualizatorul OHIF nu poate fi deschis.</span>
                    </RadzenStack>
                </RadzenAlert>
            }
            else
            {
                <RadzenText Text="Apasă 'Încarcă viewer' pentru a deschide vizualizatorul OHIF." TextStyle="TextStyle.Body2"
                            style="color: var(--rz-text-tertiary-color);" TextAlign="TextAlign.Center" class="rz-py-6" />
            }
        </RadzenCard>

        @* ── Analize pe studiu ──────────────────────────────── *@
        <RadzenCard>
            <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" class="rz-mb-2">
                <RadzenColumn Size="12" SizeMD="8">
                    <RadzenText Text="Analize pe acest studiu" TextStyle="TextStyle.H6" class="rz-mb-0" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4" class="rz-text-align-end">
                    <RadzenButton Icon="refresh" Text="Reîncarcă" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                  Click="@LoadStudyAnalyses" IsBusy="@isLoadingAnalyses" />
                </RadzenColumn>
            </RadzenRow>

            @if (isLoadingAnalyses)
            {
                <RadzenProgressBarCircular ProgressBarStyle="ProgressBarStyle.Primary" Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
            }
            else if (!studyAnalyses.Any())
            {
                <RadzenText Text="Nu există încă analize pentru acest studiu." TextStyle="TextStyle.Body2"
                            style="color: var(--rz-text-secondary-color);" />
            }
            else
            {
                <RadzenStack Gap="0.5rem">
                    @foreach (var item in studyAnalyses)
                    {
                        <RadzenCard>
                            <RadzenRow AlignItems="AlignItems.Center">
                                <RadzenColumn Size="12" SizeMD="10">
                                    <RadzenRow>
                                        <RadzenColumn Size="6" SizeMD="3">
                                            <RadzenText Text="Status" TextStyle="TextStyle.Caption" style="color: var(--rz-text-tertiary-color);" />
                                            <div>
                                                <RadzenBadge BadgeStyle="@GetStatusBadgeStyle(item.Status)" Text="@item.Status" />
                                            </div>
                                        </RadzenColumn>
                                        <RadzenColumn Size="6" SizeMD="3">
                                            <RadzenText Text="Model" TextStyle="TextStyle.Caption" style="color: var(--rz-text-tertiary-color);" />
                                            <RadzenText Text="@(item.ModelName ?? "—")" TextStyle="TextStyle.Body2" />
                                        </RadzenColumn>
                                        <RadzenColumn Size="6" SizeMD="3">
                                            <RadzenText Text="Creată la" TextStyle="TextStyle.Caption" style="color: var(--rz-text-tertiary-color);" />
                                            <RadzenText Text="@FormatDateTime(item.CreatedAt)" TextStyle="TextStyle.Body2" />
                                        </RadzenColumn>
                                        <RadzenColumn Size="6" SizeMD="3">
                                            <RadzenText Text="Încredere" TextStyle="TextStyle.Caption" style="color: var(--rz-text-tertiary-color);" />
                                            <RadzenText Text="@(item.Confidence.HasValue ? item.Confidence.Value.ToString("P2") : "—")" TextStyle="TextStyle.Body2" />
                                        </RadzenColumn>
                                    </RadzenRow>
                                </RadzenColumn>
                                <RadzenColumn Size="12" SizeMD="2" class="rz-text-align-end">
                                    <RadzenButton Icon="arrow_forward" ButtonStyle="ButtonStyle.Info" Variant="Variant.Text" Size="ButtonSize.Small"
                                                  title="Deschide analiza"
                                                  Click="@(() => OpenStudyAnalysis(item))" />
                                </RadzenColumn>
                            </RadzenRow>
                        </RadzenCard>
                    }
                </RadzenStack>
            }
        </RadzenCard>
    </RadzenStack>
}

@code {
    [Parameter] public string OrthancStudyId { get; set; } = "";

    private bool IsDoctor => TokenStore.Roles.Contains("Doctor") && !TokenStore.IsSuperAdmin;

    private Sitim.Core.Models.StudyDetails? study;
    private List<SitimApiClient.AIAnalysisJobListItemDto> studyAnalyses = new();
    private string? viewerUrl;
    private bool viewerUnavailable;
    private bool isLoading = true;
    private bool isLoadingViewer;
    private bool isLoadingAnalyses;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            study = await Api.GetLocalStudyAsync(OrthancStudyId);
            await LoadStudyAnalyses();
        }
        catch (Exception ex)
        {
            Notification.Notify(NotificationSeverity.Error, "Eroare", ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadViewerUrl()
    {
        isLoadingViewer = true;
        viewerUnavailable = false;
        try
        {
            viewerUrl = await Api.GetViewerLinkAsync(OrthancStudyId);
            if (string.IsNullOrWhiteSpace(viewerUrl))
            {
                viewerUnavailable = true;
                Notification.Notify(NotificationSeverity.Warning, "Viewer indisponibil", "Serverul PACS (Orthanc) nu este disponibil momentan.");
            }
        }
        catch (Exception ex)
        {
            viewerUnavailable = true;
            Notification.Notify(NotificationSeverity.Error, "Eroare viewer", ex.Message);
        }
        finally
        {
            isLoadingViewer = false;
        }
    }

    private async Task OpenViewerExternal()
    {
        if (!string.IsNullOrWhiteSpace(viewerUrl))
            Navigation.NavigateTo(viewerUrl, forceLoad: true);
    }

    private async Task OnSync()
    {
        try
        {
            study = await Api.SyncStudyAsync(OrthancStudyId);
            await LoadStudyAnalyses();
            Notification.Notify(NotificationSeverity.Success, "Sincronizat", "Studiul a fost sincronizat din Orthanc.");
        }
        catch (Exception ex)
        {
            Notification.Notify(NotificationSeverity.Error, "Eroare", ex.Message);
        }
    }

    // Model selection dialog + start background analysis job
    private async Task OnStartAnalysis()
    {
        if (study?.DbStudyId == null || study.DbStudyId == Guid.Empty)
        {
            Notification.Notify(NotificationSeverity.Error, "Eroare", "Studiul nu are ID din baza de date.");
            return;
        }

        try
        {
            // Get compatible models for this study (by modality)
            var models = await Api.GetCompatibleModelsAsync(study.DbStudyId.Value);
            
            if (!models.Any())
            {
                Notification.Notify(NotificationSeverity.Warning, "Niciun model disponibil", 
                    $"Nu sunt modele compatibile cu modalitatea acestui studiu ({string.Join(", ", study.ModalitiesInStudy)}).");
                return;
            }

            // Show model selection dialog
            var result = await Dialog.OpenAsync<ModelSelectionDialog>("Selectare Model pentru Analiză",
                new Dictionary<string, object?> { { "Models", models } },
                new DialogOptions { Width = "92vw", Height = "84vh", Resizable = false, Draggable = true });

            if (result is Guid selectedModelId)
            {
                // Start analysis in background (Hangfire job)
                await StartAnalysisJob(study.DbStudyId.Value, selectedModelId);
            }
        }
        catch (Exception ex)
        {
            Notification.Notify(NotificationSeverity.Error, "Eroare", $"Nu s-a putut încărca modelele: {ex.Message}");
        }
    }

    private async Task StartAnalysisJob(Guid studyId, Guid modelId)
    {
        try
        {
            var jobId = await Api.StartAnalysisAsync(studyId, modelId);
            
            Notification.Notify(NotificationSeverity.Success, "Analiză pornită", 
                $"Analiza a fost adăugată în coadă (Job ID: {jobId:N}).");
            
            // Navigate to analysis progress page to track job
            Navigation.NavigateTo($"/analysis/{jobId}");
        }
        catch (Exception ex)
        {
            Notification.Notify(NotificationSeverity.Error, "Eroare la pornire analiză", ex.Message);
        }
    }

    private async Task LoadStudyAnalyses()
    {
        if (study?.DbStudyId == null || study.DbStudyId == Guid.Empty)
        {
            studyAnalyses = new();
            return;
        }

        isLoadingAnalyses = true;
        try
        {
            studyAnalyses = await Api.GetStudyAnalysisJobsAsync(study.DbStudyId.Value);
        }
        catch (Exception ex)
        {
            Notification.Notify(NotificationSeverity.Error, "Eroare analize", ex.Message);
            studyAnalyses = new();
        }
        finally
        {
            isLoadingAnalyses = false;
        }
    }

    private void OpenStudyAnalysis(SitimApiClient.AIAnalysisJobListItemDto analysisJob)
    {
        var path = analysisJob.Status == "Completed"
            ? $"/analysis/{analysisJob.Id}/results"
            : $"/analysis/{analysisJob.Id}";
        Navigation.NavigateTo(path);
    }

    private static BadgeStyle GetStatusBadgeStyle(string status) => status switch
    {
        "Queued" => BadgeStyle.Warning,
        "Running" => BadgeStyle.Info,
        "Completed" => BadgeStyle.Success,
        "Failed" => BadgeStyle.Danger,
        _ => BadgeStyle.Light
    };

    private static string FormatDateTime(DateTime dt)
    {
        return dt.ToString("yyyy-MM-dd HH:mm:ss");
    }

    private static string FormatStudyDate(string? date)
    {
        if (string.IsNullOrWhiteSpace(date) || date.Length < 8) return date ?? "—";
        return $"{date[6..8]}.{date[4..6]}.{date[0..4]}";
    }
}
