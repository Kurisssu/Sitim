@page "/set-password"
@using Sitim.Web.Services
@layout MainLayout
@inject SitimApiClient Api
@inject NavigationManager Navigation

<PageTitle>Setare parolă — SITIM</PageTitle>

<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--rz-base-background-color);">
    <RadzenCard Style="min-width:380px;max-width:480px;padding:2.5rem;box-shadow:var(--rz-shadow-4);">
        <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem" class="rz-mb-4">
            <RadzenIcon Icon="biotech" style="font-size:48px;color:var(--rz-primary);" />
            <RadzenText Text="SITIM" TextStyle="TextStyle.H4" class="rz-mb-0" />
            <RadzenText Text="Setare parolă cont nou" TextStyle="TextStyle.Body2"
                        style="color:var(--rz-text-tertiary-color);" />
        </RadzenStack>

        @if (_done)
        {
            <RadzenAlert AlertStyle="AlertStyle.Success" AllowClose="false" class="rz-mb-3">
                Parola a fost setată cu succes! Vă puteți autentifica acum.
            </RadzenAlert>
            <RadzenButton Text="Mergi la autentificare" Icon="login" ButtonStyle="ButtonStyle.Primary"
                          Style="width:100%" Click="@(() => Navigation.NavigateTo("/login"))" />
        }
        else if (_invalidLink)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" AllowClose="false">
                Linkul de invitație este invalid sau a expirat. Solicitați un link nou administratorului.
            </RadzenAlert>
        }
        else
        {
            <RadzenStack Gap="1rem">
                <RadzenFormField Text="Parolă nouă *" Style="width:100%">
                    <ChildContent>
                        <RadzenPassword @bind-Value="_password" Placeholder="Minim 8 caractere" Style="width:100%" />
                    </ChildContent>
                </RadzenFormField>
                <RadzenFormField Text="Confirmare parolă *" Style="width:100%">
                    <ChildContent>
                        <RadzenPassword @bind-Value="_confirm" Placeholder="Repetați parola" Style="width:100%" />
                    </ChildContent>
                </RadzenFormField>

                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" AllowClose="false" Size="AlertSize.Small">
                        @_error
                    </RadzenAlert>
                }

                <RadzenButton Text="Setează parola" Icon="lock" ButtonStyle="ButtonStyle.Primary"
                              Style="width:100%;margin-top:0.5rem"
                              Click="@Submit" IsBusy="@_busy" BusyText="Se procesează..." />
            </RadzenStack>
        }
    </RadzenCard>
</div>

@code {
    [SupplyParameterFromQuery] public Guid UserId { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }

    private string _password = "";
    private string _confirm = "";
    private string? _error;
    private bool _busy = false;
    private bool _done = false;
    private bool _invalidLink = false;

    protected override void OnParametersSet()
    {
        if (UserId == Guid.Empty || string.IsNullOrWhiteSpace(Token))
            _invalidLink = true;
    }

    private async Task Submit()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_password) || _password.Length < 8)
        {
            _error = "Parola trebuie să aibă cel puțin 8 caractere.";
            return;
        }
        if (_password != _confirm)
        {
            _error = "Parolele nu coincid.";
            return;
        }

        _busy = true;
        var ok = await Api.SetPasswordAsync(UserId, Token!, _password);
        _busy = false;

        if (ok)
        {
            _done = true;
        }
        else
        {
            _error = "Linkul a expirat sau parola nu respectă cerințele (minim 8 caractere, literă mare, cifră, caracter special).";
        }
    }
}
