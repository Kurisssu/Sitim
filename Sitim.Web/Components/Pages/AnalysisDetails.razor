@page "/analyses/{Id:guid}"
@attribute [Authorize]
@inject SitimApiClient Api
@inject NavigationManager Navigation
@inject NotificationService Notification
@implements IDisposable

<PageTitle>Detalii analiză — SITIM</PageTitle>

@if (isLoading)
{
    <RadzenProgressBarCircular ProgressBarStyle="ProgressBarStyle.Primary" Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
else if (job is null)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Dark" AllowClose="false">
        Analiza nu a fost găsită.
    </RadzenAlert>
}
else
{
    <RadzenStack Gap="1rem">
        @* ── Header ──────────────────────────────────── *@
        <RadzenRow AlignItems="AlignItems.Center">
            <RadzenColumn Size="12" SizeMD="8">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenButton Icon="arrow_back" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Size="ButtonSize.Small"
                                  Click="@(() => Navigation.NavigateTo("/analyses"))" title="Înapoi la Analize" />
                    <RadzenText Text="Detalii Analiză" TextStyle="TextStyle.DisplayH5" class="rz-mb-0" />
                    <RadzenBadge BadgeStyle="@GetBadge(job.Status)" Text="@TranslateStatus(job.Status)" />
                </RadzenStack>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
                    @if (job.Status == "Failed")
                    {
                        <RadzenButton Text="Re-rulează" Icon="replay" ButtonStyle="ButtonStyle.Warning" Size="ButtonSize.Small"
                                      Click="@OnReenqueue" />
                    }
                    <RadzenButton Text="Studiu" Icon="visibility" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                  Click="@(() => Navigation.NavigateTo($"/studies/{job.OrthancStudyId}"))" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>

        @* ── Auto-refresh indicator ─────────────────── *@
        @if (isPolling)
        {
            <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Dark" AllowClose="false" Size="AlertSize.Small">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenProgressBarCircular ProgressBarStyle="ProgressBarStyle.Info" Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.ExtraSmall" />
                    <span>Se actualizează automat la fiecare 3 secunde...</span>
                </RadzenStack>
            </RadzenAlert>
        }

        @* ── Informații job ──────────────────────────── *@
        <RadzenCard>
            <RadzenText Text="Informații job" TextStyle="TextStyle.H6" class="rz-mb-3" />
            <RadzenRow>
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenStack Gap="0.5rem">
                        <RadzenFormField Text="ID Analiză" Variant="Variant.Text"><ChildContent><RadzenTextBox ReadOnly="true" Value="@job.Id.ToString()" Style="width: 100%; font-family: monospace; font-size: 0.85rem;" /></ChildContent></RadzenFormField>
                        <RadzenFormField Text="Orthanc Study ID" Variant="Variant.Text"><ChildContent><RadzenTextBox ReadOnly="true" Value="@job.OrthancStudyId" Style="width: 100%; font-family: monospace; font-size: 0.85rem;" /></ChildContent></RadzenFormField>
                        <RadzenFormField Text="Model" Variant="Variant.Text"><ChildContent><RadzenTextBox ReadOnly="true" Value="@job.ModelKey" Style="width: 100%;" /></ChildContent></RadzenFormField>
                    </RadzenStack>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenStack Gap="0.5rem">
                        <RadzenFormField Text="Creat" Variant="Variant.Text"><ChildContent><RadzenTextBox ReadOnly="true" Value="@job.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")" Style="width: 100%;" /></ChildContent></RadzenFormField>
                        <RadzenFormField Text="Început" Variant="Variant.Text"><ChildContent><RadzenTextBox ReadOnly="true" Value="@(job.StartedAtUtc?.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss") ?? "—")" Style="width: 100%;" /></ChildContent></RadzenFormField>
                        <RadzenFormField Text="Finalizat" Variant="Variant.Text"><ChildContent><RadzenTextBox ReadOnly="true" Value="@(job.FinishedAtUtc?.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss") ?? "—")" Style="width: 100%;" /></ChildContent></RadzenFormField>
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
        </RadzenCard>

        @* ── Eroare (dacă Failed) ────────────────────── *@
        @if (job.Status == "Failed" && !string.IsNullOrWhiteSpace(job.ErrorMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Dark" AllowClose="false" Title="Eroare">
                @job.ErrorMessage
            </RadzenAlert>
        }

        @* ── Rezultat (dacă Succeeded) ───────────────── *@
        @if (job.Status == "Succeeded")
        {
            <RadzenCard>
                <RadzenText Text="Rezultat analiză" TextStyle="TextStyle.H6" class="rz-mb-3" />
                @if (isLoadingResult)
                {
                    <RadzenProgressBarCircular ProgressBarStyle="ProgressBarStyle.Primary" Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
                }
                else if (!string.IsNullOrWhiteSpace(resultJson))
                {
                    <pre style="background: var(--rz-base-800); color: var(--rz-text-color); padding: 1rem; border-radius: var(--rz-border-radius); overflow-x: auto; max-height: 500px; font-size: 0.85rem;">@resultJson</pre>
                }
                else
                {
                    <RadzenText Text="Rezultatul nu este disponibil." TextStyle="TextStyle.Body2" style="color: var(--rz-text-tertiary-color);" />
                }
            </RadzenCard>
        }
    </RadzenStack>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private AnalysisJobDto? job;
    private string? resultJson;
    private bool isLoading = true;
    private bool isLoadingResult;
    private bool isPolling;
    private Timer? pollTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadJob();
        StartPollingIfNeeded();
    }

    private async Task LoadJob()
    {
        isLoading = true;
        try
        {
            job = await Api.GetAnalysisAsync(Id);
            if (job?.Status == "Succeeded" && string.IsNullOrWhiteSpace(resultJson))
            {
                await LoadResult();
            }
        }
        catch (Exception ex)
        {
            Notification.Notify(NotificationSeverity.Error, "Eroare", ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadResult()
    {
        isLoadingResult = true;
        try
        {
            resultJson = await Api.GetAnalysisResultAsync(Id);
            // Pretty-print JSON
            if (!string.IsNullOrWhiteSpace(resultJson))
            {
                try
                {
                    var doc = System.Text.Json.JsonDocument.Parse(resultJson);
                    resultJson = System.Text.Json.JsonSerializer.Serialize(doc, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
                }
                catch { /* keep as-is */ }
            }
        }
        catch (Exception ex)
        {
            Notification.Notify(NotificationSeverity.Error, "Eroare rezultat", ex.Message);
        }
        finally
        {
            isLoadingResult = false;
        }
    }

    private void StartPollingIfNeeded()
    {
        if (job is not null && (job.Status == "Queued" || job.Status == "Running"))
        {
            isPolling = true;
            pollTimer = new Timer(async _ =>
            {
                try
                {
                    var updated = await Api.GetAnalysisAsync(Id);
                    if (updated is not null)
                    {
                        job = updated;
                        if (job.Status == "Succeeded")
                        {
                            await LoadResult();
                            StopPolling();
                        }
                        else if (job.Status == "Failed")
                        {
                            StopPolling();
                        }
                    }
                    await InvokeAsync(StateHasChanged);
                }
                catch { /* ignore polling errors */ }
            }, null, TimeSpan.FromSeconds(3), TimeSpan.FromSeconds(3));
        }
    }

    private void StopPolling()
    {
        isPolling = false;
        pollTimer?.Dispose();
        pollTimer = null;
    }

    private async Task OnReenqueue()
    {
        var ok = await Api.ReenqueueAnalysisAsync(Id);
        if (ok)
        {
            Notification.Notify(NotificationSeverity.Success, "Re-rulat", "Analiza a fost reprogramată.");
            await LoadJob();
            StartPollingIfNeeded();
        }
        else
        {
            Notification.Notify(NotificationSeverity.Error, "Eroare", "Nu s-a putut re-rula analiza.");
        }
    }

    private static BadgeStyle GetBadge(string status) => status switch
    {
        "Queued" => BadgeStyle.Warning,
        "Running" => BadgeStyle.Info,
        "Succeeded" => BadgeStyle.Success,
        "Failed" => BadgeStyle.Danger,
        _ => BadgeStyle.Light
    };

    private static string TranslateStatus(string status) => status switch
    {
        "Queued" => "În așteptare",
        "Running" => "Rulează",
        "Succeeded" => "Finalizat",
        "Failed" => "Eșuat",
        _ => status
    };

    public void Dispose()
    {
        pollTimer?.Dispose();
    }
}
