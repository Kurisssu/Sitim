@page "/federated-learning"
@attribute [Authorize(Roles = "SuperAdmin")]
@implements IAsyncDisposable
@inject SitimApiClient Api
@inject NavigationManager Navigation
@inject NotificationService Notification

<PageTitle>Federated Learning — SITIM</PageTitle>

<RadzenStack Gap="1rem">
    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenColumn Size="12" SizeMD="7">
            <RadzenText Text="Federated Learning" TextStyle="TextStyle.DisplayH5" class="rz-mb-0" />
            <RadzenText Text="Sesiuni FL active și istoricul rundelor de antrenare" TextStyle="TextStyle.Body2" style="color: var(--rz-text-secondary-color);" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="5" class="rz-text-align-end">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
                <RadzenButton Text="Sesiune nouă" Icon="play_circle" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                              Click="@OpenCreateDialog" Disabled="@_loading" />
                <RadzenButton Text="Reîncarcă" Icon="refresh" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small"
                              Click="@LoadSessionsAsync" IsBusy="@_loading" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End">
        <RadzenColumn Size="12" SizeMD="4" class="rz-text-align-end">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
                <RadzenCheckBox @bind-Value="_autoRefresh" TValue="bool" />
                <RadzenText Text="Auto-refresh (5 sec)" TextStyle="TextStyle.Body2" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>

    <RadzenCard>
        <RadzenStack Gap="0.5rem">
            <RadzenText Text="Clienți FL conectați (handshake instituție)" TextStyle="TextStyle.Body1" />
            @if (!_connectedClients.Any(c => c.IsOnline))
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Light" AllowClose="false">
                    Nu există clienți FL online. Configurează fiecare container cu <b>FL_INSTITUTION_ID=&lt;InstitutionId GUID&gt;</b>.
                </RadzenAlert>
            }
            else
            {
                <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
                    @foreach (var client in _connectedClients.Where(c => c.IsOnline).OrderBy(c => c.InstitutionId))
                    {
                        <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="@GetConnectedClientBadgeText(client)" />
                    }
                </div>
            }
        </RadzenStack>
    </RadzenCard>

    @if (_loading)
    {
        <RadzenProgressBarCircular ProgressBarStyle="ProgressBarStyle.Primary" Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    }
    else if (!_sessions.Any())
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Light" AllowClose="false">
            Nu există sesiuni FL create.
        </RadzenAlert>
    }
    else
    {
        <RadzenStack Gap="0.5rem">
            @foreach (var session in _sessions.OrderByDescending(s => s.CreatedAtUtc))
            {
                <RadzenCard>
                    <RadzenRow AlignItems="AlignItems.Center">
                        <RadzenColumn Size="12" SizeMD="10">
                            <RadzenRow>
                                <RadzenColumn Size="6" SizeMD="3">
                                    <RadzenText Text="Model" TextStyle="TextStyle.Caption" style="color: var(--rz-text-tertiary-color);" />
                                    <RadzenText Text="@session.ModelKey" TextStyle="TextStyle.Body2" />
                                </RadzenColumn>
                                <RadzenColumn Size="6" SizeMD="2">
                                    <RadzenText Text="Status" TextStyle="TextStyle.Caption" style="color: var(--rz-text-tertiary-color);" />
                                    <div>
                                        <RadzenBadge BadgeStyle="@GetSessionBadgeStyle(session.Status)" Text="@session.Status" />
                                    </div>
                                </RadzenColumn>
                                <RadzenColumn Size="6" SizeMD="2">
                                    <RadzenText Text="Runde" TextStyle="TextStyle.Caption" style="color: var(--rz-text-tertiary-color);" />
                                    <RadzenText Text="@($"{session.CurrentRound}/{session.TotalRounds}")" TextStyle="TextStyle.Body2" />
                                </RadzenColumn>
                                <RadzenColumn Size="6" SizeMD="2">
                                    <RadzenText Text="Participanți" TextStyle="TextStyle.Caption" style="color: var(--rz-text-tertiary-color);" />
                                    <RadzenText Text="@session.ParticipantsCount.ToString()" TextStyle="TextStyle.Body2" />
                                </RadzenColumn>
                                <RadzenColumn Size="6" SizeMD="3">
                                    <RadzenText Text="Creată la" TextStyle="TextStyle.Caption" style="color: var(--rz-text-tertiary-color);" />
                                    <RadzenText Text="@FormatDateTime(session.CreatedAtUtc)" TextStyle="TextStyle.Body2" />
                                </RadzenColumn>
                            </RadzenRow>
                        </RadzenColumn>
                        <RadzenColumn Size="12" SizeMD="2" class="rz-text-align-end">
                            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.25rem">
                                <RadzenButton Icon="visibility" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.Small" Variant="Variant.Text"
                                              title="Detalii sesiune"
                                              Click="@(() => Navigation.NavigateTo($"/federated-learning/sessions/{session.Id}"))" />
                                @if (IsSessionRunning(session.Status))
                                {
                                    <RadzenButton Icon="stop_circle" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Variant="Variant.Text"
                                                  title="Oprește sesiunea"
                                                  Click="@(() => StopSessionAsync(session.Id))" />
                                }
                            </RadzenStack>
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenCard>
            }
        </RadzenStack>
    }
</RadzenStack>

@if (_showCreateDialog)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;display:flex;align-items:center;justify-content:center;">
        <RadzenCard Style="min-width:440px;max-width:680px;padding:2rem;box-shadow:var(--rz-shadow-4);">
            <RadzenText Text="Sesiune FL nouă" TextStyle="TextStyle.H6" class="rz-mb-4" />
            <RadzenStack Gap="1rem">
                <RadzenFormField Text="Cheie model *" Style="width:100%">
                    <ChildContent>
                        <RadzenTextBox @bind-Value="_newModelKey" Style="width:100%" Placeholder="ex: retinopathy_resnet18" />
                    </ChildContent>
                </RadzenFormField>

                <RadzenFormField Text="Număr total runde *" Style="width:100%">
                    <ChildContent>
                        <RadzenNumeric @bind-Value="_newTotalRounds" Min="1" Step="1" TValue="int" Style="width:100%" />
                    </ChildContent>
                </RadzenFormField>

                <RadzenFormField Text="Instituții participante *" Style="width:100%">
                    <ChildContent>
                        <RadzenDropDown @bind-Value="_selectedInstitutionIds"
                                        Data="@_institutions.Where(i => i.IsActive).OrderBy(i => i.Name).ToList()"
                                        TextProperty="Name"
                                        ValueProperty="Id"
                                        Multiple="true"
                                        Chips="true"
                                        AllowClear="true"
                                        Placeholder="Selectați instituțiile participante"
                                        Style="width:100%" />
                    </ChildContent>
                    <Helper>
                        <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-tertiary-color);">
                            Selectați minimum o instituție activă. Doar instituțiile cu client FL conectat pot porni sesiunea.
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-tertiary-color);">
                            Conectate acum: @_connectedClients.Count(c => c.IsOnline) / @_institutions.Count(i => i.IsActive)
                        </RadzenText>
                    </Helper>
                </RadzenFormField>

                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem" class="rz-mt-2">
                    <RadzenButton Text="Anulare" ButtonStyle="ButtonStyle.Light" Click="@CloseCreateDialog" />
                    <RadzenButton Text="Pornește sesiunea" Icon="play_circle" ButtonStyle="ButtonStyle.Primary"
                                  Click="@CreateSessionAsync" IsBusy="@_saving" />
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>
    </div>
}

@code {
    private List<SitimApiClient.FLSessionDto> _sessions = [];
    private List<SitimApiClient.InstitutionResult> _institutions = [];
    private List<SitimApiClient.FLConnectedClientDto> _connectedClients = [];
    private bool _loading = true;
    private bool _saving;
    private bool _autoRefresh = true;
    private System.Timers.Timer? _refreshTimer;

    private bool _showCreateDialog;
    private string _newModelKey = "retinopathy_resnet18";
    private int _newTotalRounds = 10;
    private List<Guid> _selectedInstitutionIds = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        StartAutoRefresh();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var sessionsTask = Api.GetFLSessionsAsync();
            var institutionsTask = Api.GetInstitutionsAsync();
            var clientsTask = Api.GetFLConnectedClientsAsync();
            await Task.WhenAll(sessionsTask, institutionsTask, clientsTask);

            _sessions = sessionsTask.Result ?? [];
            _institutions = institutionsTask.Result ?? [];
            _connectedClients = clientsTask.Result ?? [];
        }
        catch (Exception ex)
        {
            Notification.Notify(NotificationSeverity.Error, "Eroare", ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadSessionsAsync()
    {
        _loading = true;
        try
        {
            var sessionsTask = Api.GetFLSessionsAsync();
            var clientsTask = Api.GetFLConnectedClientsAsync();
            await Task.WhenAll(sessionsTask, clientsTask);
            _sessions = sessionsTask.Result ?? [];
            _connectedClients = clientsTask.Result ?? [];
        }
        catch (Exception ex)
        {
            Notification.Notify(NotificationSeverity.Error, "Eroare", ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    private void StartAutoRefresh()
    {
        _refreshTimer = new System.Timers.Timer(5000);
        _refreshTimer.Elapsed += (_, _) =>
        {
            if (!_autoRefresh || !_sessions.Any(s => IsSessionRunning(s.Status)))
                return;

            _ = InvokeAsync(LoadSessionsAsync);
        };
        _refreshTimer.AutoReset = true;
        _refreshTimer.Start();
    }

    private void OpenCreateDialog()
    {
        _newModelKey = "retinopathy_resnet18";
        _newTotalRounds = 10;
        _selectedInstitutionIds = [];
        _showCreateDialog = true;
    }

    private void CloseCreateDialog()
    {
        _showCreateDialog = false;
    }

    private async Task CreateSessionAsync()
    {
        if (string.IsNullOrWhiteSpace(_newModelKey))
        {
            Notification.Notify(NotificationSeverity.Warning, "Validare", "Completați cheia modelului.");
            return;
        }

        if (_newTotalRounds <= 0)
        {
            Notification.Notify(NotificationSeverity.Warning, "Validare", "Numărul de runde trebuie să fie mai mare decât 0.");
            return;
        }

        if (_selectedInstitutionIds.Count == 0)
        {
            Notification.Notify(NotificationSeverity.Warning, "Validare", "Selectați minimum o instituție participantă.");
            return;
        }

        var missingConnectedInstitutionIds = GetMissingConnectedInstitutionIds(_selectedInstitutionIds);
        if (missingConnectedInstitutionIds.Count > 0)
        {
            var missingLabels = missingConnectedInstitutionIds
                .Select(GetInstitutionLabel)
                .OrderBy(v => v)
                .ToList();
            Notification.Notify(
                NotificationSeverity.Warning,
                "Client FL lipsă",
                "Instituții fără client FL online: " + string.Join(", ", missingLabels));
            return;
        }

        _saving = true;
        try
        {
            var created = await Api.StartFLSessionAsync(_newModelKey.Trim(), _newTotalRounds, _selectedInstitutionIds);
            if (created is null)
            {
                Notification.Notify(NotificationSeverity.Error, "Eroare", "Nu s-a putut porni sesiunea FL.");
                return;
            }

            Notification.Notify(NotificationSeverity.Success, "Succes", $"Sesiunea FL {created.Id} a fost pornită.");
            _showCreateDialog = false;
            await LoadSessionsAsync();
        }
        catch (Exception ex)
        {
            Notification.Notify(NotificationSeverity.Error, "Eroare", ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task StopSessionAsync(Guid sessionId)
    {
        try
        {
            var stopped = await Api.StopFLSessionAsync(sessionId);
            if (!stopped)
            {
                Notification.Notify(NotificationSeverity.Error, "Eroare", "Nu s-a putut opri sesiunea FL.");
                return;
            }

            Notification.Notify(NotificationSeverity.Warning, "Sesiune oprită", $"Sesiunea {sessionId} a fost oprită.");
            await LoadSessionsAsync();
        }
        catch (Exception ex)
        {
            Notification.Notify(NotificationSeverity.Error, "Eroare", ex.Message);
        }
    }

    private static bool IsSessionRunning(string status) =>
        status is "Running" or "Pending";

    private List<Guid> GetMissingConnectedInstitutionIds(IEnumerable<Guid> selectedInstitutionIds)
    {
        var connectedInstitutionIds = _connectedClients
            .Where(c => c.IsOnline)
            .Select(c => c.InstitutionId)
            .ToHashSet();

        return selectedInstitutionIds
            .Where(id => !connectedInstitutionIds.Contains(id))
            .Distinct()
            .ToList();
    }

    private string GetInstitutionLabel(Guid institutionId)
    {
        var institution = _institutions.FirstOrDefault(i => i.Id == institutionId);
        return institution is null ? institutionId.ToString() : $"{institution.Name} ({institution.Id})";
    }

    private string GetConnectedClientBadgeText(SitimApiClient.FLConnectedClientDto client)
    {
        var institution = _institutions.FirstOrDefault(i => i.Id == client.InstitutionId);
        var institutionLabel = institution?.Name ?? client.InstitutionId.ToString();
        return $"{institutionLabel} · {client.ClientId}";
    }

    private static BadgeStyle GetSessionBadgeStyle(string status) => status switch
    {
        "Pending" => BadgeStyle.Warning,
        "Running" => BadgeStyle.Info,
        "Completed" => BadgeStyle.Success,
        "Stopped" => BadgeStyle.Danger,
        "Failed" => BadgeStyle.Danger,
        _ => BadgeStyle.Light
    };

    private static string FormatDateTime(DateTime value) => value.ToString("yyyy-MM-dd HH:mm:ss");

    public ValueTask DisposeAsync()
    {
        _refreshTimer?.Dispose();
        return ValueTask.CompletedTask;
    }
}
